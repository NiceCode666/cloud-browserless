# ============================================================
# cloud-browserless 配置模板
#
# 用法:
#   1. 拷一份给 deploy.sh 用 (首次部署时 deploy.sh 会自动生成，这里是参考)
#   2. 直接改服务器上的 /opt/cloud-browser/.env，再 ./deploy.sh root@host
#   3. 以 # 开头的是注释，可删可改
#
# 所有字段都有合理默认值，最小配置只需要 WEB_PASSWORD 和 CDP_TOKEN。
# ============================================================

# ---- 必填：凭据 ----
WEB_USER=admin
WEB_PASSWORD=<随机 20 位强密码>
CDP_TOKEN=<随机 48 位十六进制>

# ---- 端口（对外暴露，需与防火墙/安全组匹配）----
WEB_PORT=3000         # Web UI (HTTPS)
CDP_PORT=9222         # CDP (HTTP + token)

# ---- 时区 ----
TZ=Asia/Shanghai

# ============================================================
# 画质调优  —— 根据机器规格选预设
# ============================================================
#
# 画质越高：体验越好，但需要更多 CPU 编码 + 更多带宽。
# 改完需要 ./deploy.sh root@host 重跑以应用。
#
# ----- 【低配预设】2 vCPU / 3~4 GB RAM（当前默认值）-----
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=720
DISPLAY_DPI=96
SELKIES_FRAMERATE=30
SELKIES_VIDEO_BITRATE=4000          # kbps
SELKIES_AUDIO_BITRATE=64000         # bps
SELKIES_ENCODER=x264enc             # 软编；有 GPU 可改 vah264enc / nvh264enc

# ----- 【中配预设】4 vCPU / 8 GB RAM（推荐生产）-----
# DISPLAY_WIDTH=1920
# DISPLAY_HEIGHT=1080
# SELKIES_FRAMERATE=60
# SELKIES_VIDEO_BITRATE=8000
# SELKIES_AUDIO_BITRATE=128000

# ----- 【高配预设】8 vCPU / 16 GB RAM 或带 GPU -----
# DISPLAY_WIDTH=1920
# DISPLAY_HEIGHT=1200
# SELKIES_FRAMERATE=60
# SELKIES_VIDEO_BITRATE=12000
# SELKIES_AUDIO_BITRATE=128000
# SELKIES_ENCODER=vah264enc            # Intel/AMD VAAPI 硬编
# # SELKIES_ENCODER=nvh264enc          # NVIDIA 硬编（需要挂 /dev/nvidia*）

# ============================================================
# 资源上限（低配必须设，防止 chromium 拖死 sshd / docker daemon）
# ============================================================
#
# mem_limit:   容器硬性内存上限，超出会被 OOM-kill
# cpus:        CPU 上限（支持小数，1.5 = 1.5 核）
# shm_size:    容器 /dev/shm 大小，chromium 有 --disable-dev-shm-usage 所以不用太大
#
# 【低配】2 vCPU / 3.4 GB RAM：
CHROMIUM_MEM_LIMIT=2g
CHROMIUM_CPUS=1.5
CHROMIUM_SHM_SIZE=1g
GATEWAY_MEM_LIMIT=128m

# 【中配】4 vCPU / 8 GB RAM：
# CHROMIUM_MEM_LIMIT=6g
# CHROMIUM_CPUS=3
# CHROMIUM_SHM_SIZE=2g
# GATEWAY_MEM_LIMIT=256m

# 【高配】8 vCPU / 16 GB RAM：
# CHROMIUM_MEM_LIMIT=12g
# CHROMIUM_CPUS=6
# CHROMIUM_SHM_SIZE=2g

# ============================================================
# Chromium 启动参数
# ============================================================
#
# 【低配】开启 Chromium 低内存模式（V8 堆上限、进程限制、禁用后台特性）
CHROMIUM_LOW_MEMORY_MODE=1
CHROMIUM_JS_HEAP_MB=512

# 【高配】关掉低内存模式、不限 V8 堆：
# CHROMIUM_LOW_MEMORY_MODE=0
# CHROMIUM_JS_HEAP_MB=2048

# 额外 chromium 启动参数（空格分隔），很少需要
# CHROMIUM_EXTRA_FLAGS=--lang=zh-CN --disable-gpu-sandbox
CHROMIUM_EXTRA_FLAGS=

# ============================================================
# 生产建议
# ============================================================
#
# 1. Swap：低配机器强烈建议加 2GB swap（部署脚本里 --swap 2g）。
#    没 swap，一旦内存吃紧就是 thrashing，load average 会飙到 10+。
#
# 2. 机器规格对照：
#      2C/3G  → 能用（需本文件的低配预设 + swap）
#      4C/8G  → 流畅
#      8C/16G → 丝滑
#      带 GPU → 接近本地体验
#
# 3. 升级路径：
#      升完机器 → 改本文件的预设为中/高配 → ./deploy.sh root@host 重跑。
#      密码和 token 不会重置（除非加 --rotate）。
